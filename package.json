  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "continuity:check": "node scripts/continuity/validate-continuity.mjs",
    "session:new": "node scripts/continuity/new-session-branch.mjs",
    "session:start": "node scripts/continuity/session-start.mjs",
    "session:end": "node scripts/continuity/session-end.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "rag:evaluate:canonical:didatico": "python scripts/corpus/evaluate_rag_batch.py --questions scripts/corpus/data/2026-04-05-rag-canonical-questions.json --output docs/operational-reports/data/latest-rag-canonical-didatico.json --summary-output docs/operational-reports/data/latest-rag-canonical-didatico-summary.json --response-mode didatico --min-http-ok 16 --min-no-web-fallback 16 --min-scope-exact 15 --min-expected-all-met 15 --min-avg-final-confidence 0.95",
    "rag:evaluate:canonical:direto": "python scripts/corpus/evaluate_rag_batch.py --questions scripts/corpus/data/2026-04-05-rag-canonical-questions.json --output docs/operational-reports/data/latest-rag-canonical-direto.json --summary-output docs/operational-reports/data/latest-rag-canonical-direto-summary.json --response-mode direto --min-http-ok 16 --min-no-web-fallback 16 --min-scope-exact 15 --min-expected-all-met 15 --min-avg-final-confidence 0.95",
    "rag:evaluate:canonical": "npm run rag:evaluate:canonical:didatico && npm run rag:evaluate:canonical:direto",
    "rag:reembed:active": "python scripts/corpus/reembed_active_corpus.py",
    "corpus:validate:freshness": "python scripts/corpus/validate_corpus_freshness.py",
    "corpus:experiment:chunking": "python scripts/corpus/evaluate_chunk_profiles.py",
    "corpus:analyze:prompt-cache": "python scripts/corpus/evaluate_prompt_cache_readiness.py",
    "validate": "npm run typecheck && npm run lint && npm test && npm run build"
  },
